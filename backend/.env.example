# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=""

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=""

# Supabase Auth credentials
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Cloudflare R2 (stockage de photos)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=infradrenphotos
# Optionnel : endpoint personnalisé ou domaine public
# R2_ENDPOINT=
# R2_PUBLIC_URL=

# IA (chat assistant) — compatible OpenAI et Groq
OPEN_API_KEY=
# Optionnel : URL de base de l'API (défaut: https://api.groq.com/openai/v1)
# IA_API_URL=https://api.groq.com/openai/v1
# Optionnel : modèle IA (défaut: llama-3.3-70b-versatile)
# IA_MODEL=llama-3.3-70b-versatile
